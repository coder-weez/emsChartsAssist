{
    "name": "EMSCharts Assist",
    "short_name": "ChartAssist",
    "version": "0.3.0.0",
    "version_name": "0.3.0 (Manifest V3)",
    "description": "Autofills EMSCharts with defaults.",
    "manifest_version": 3,
    "minimum_chrome_version": "88",
    "icons": {
        "16": "icon_16.png",
        "48": "icon_48.png",
        "128": "icon_128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*.emscharts.com/pr/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://*.emscharts.com/pr/page2.cfm*"
            ],
            "js": [
                "jquery-3.7.1.min.js",
                "chartassist.js",
                "page2.js"
            ],
            "run_at": "document_start",
            "css": [
                "chartassist.css"
            ]
        },
        {
            "matches": [
                "https://*.emscharts.com/pr/page3.cfm*"
            ],
            "js": [
                "jquery-3.7.1.min.js",
                "chartassist.js",
                "page3.js"
            ],
            "run_at": "document_start",
            "css": [
                "chartassist.css"
            ]
        },
        {
            "matches": [
                "https://*.emscharts.com/pr/page4.cfm*"
            ],
            "js": [
                "jquery-3.7.1.min.js",
                "chartassist.js",
                "page4.js"
            ],
            "run_at": "document_start",
            "css": [
                "chartassist.css"
            ]
        },
        {
            "matches": [
                "https://*.emscharts.com/pr/page5.cfm*"
            ],
            "js": [
                "jquery-3.7.1.min.js",
                "chartassist.js",
                "page5.js"
            ],
            "run_at": "document_start",
            "css": [
                "chartassist.css"
            ]
        },
        {
            "matches": [
                "https://*.emscharts.com/pr/page8.cfm*"
            ],
            "js": [
                "jquery-3.7.1.min.js",
                "chartassist.js",
                "page8.js"
            ],
            "run_at": "document_start",
            "css": [
                "chartassist.css"
            ]
        }
    ],
    "action": {
        "default_title": "EMSCharts Assist",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon_16.png",
            "48": "icon_48.png",
            "128": "icon_128.png"
        }
    }
}
